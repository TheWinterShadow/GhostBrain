# Local development configuration
# Copy to .env and fill in your values
# Note: For local development, these keys work without the GHOST_BRAIN_ prefix in the .env file.
# For Cloud Run deployment, environment variables must be prefixed with GHOST_BRAIN_.

GROQ_API_KEY=gsk_...
DEEPGRAM_API_KEY=...
OPENAI_API_KEY=sk-...
GCP_BUCKET_NAME=your-bucket-name
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
